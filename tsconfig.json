{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true
  },
  "include": ["src", "plugins/building-blocks/skills/**/files"],
  "_comment": "fonts.ts + tailwind.config.ts are copy-into-your-app templates importing target-app deps (next/font, geist, tailwindcss) not installed in this playground; excluded from the playground type-check.",
  "exclude": [
    "plugins/building-blocks/skills/design-standard/files/fonts.ts",
    "plugins/building-blocks/skills/design-standard/files/tailwind.config.ts"
  ]
}
